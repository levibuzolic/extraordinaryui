#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
DEMO_DIR="${ROOT_DIR}/demo"

if ! command -v mise >/dev/null 2>&1; then
  echo "error: required command 'mise' is not installed or not on PATH" >&2
  exit 1
fi

cd "$DEMO_DIR"
# exec mise exec -- mix deps.clean demo --build
exec mise exec -- mix phx.server "$@"
