<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cinder UI</title>
    <meta
      name="description"
      content="Phoenix + LiveView component library with shadcn-inspired patterns, typed HEEx APIs, and installer tooling for existing apps."
    />
    <%= theme_bootstrap_script %>
    <link rel="stylesheet" href="<%= theme_css_path %>" />
    <link rel="stylesheet" href="<%= site_css_path %>" />
    <script type="application/speculationrules">
      {
        "prefetch": [
          {
            "source": "document",
            "where": {
              "href_matches": "/docs/*"
            },
            "eagerness": "eager"
          }
        ]
      }
    </script>
  </head>
  <body class="bg-background text-foreground">
    <header class="border-b bg-card/80 backdrop-blur-sm sticky top-0 z-40">
      <div class="mx-auto flex max-w-[1200px] flex-wrap items-center justify-between gap-3 px-4 py-3 md:px-6">
        <a href="./" class="bp-mono text-lg font-semibold tracking-tight">Cinder UI</a>
        <%= header_controls_html %>
      </div>
    </header>

    <div class="site-shell mx-auto max-w-[1200px] px-4 py-6 md:px-6">
      <main class="space-y-12">
        <%= hero_html %>
        <%= component_examples_html %>
        <%= install_html %>
        <%= features_html %>
      </main>

      <%= footer_html %>
    </div>
    <script type="module" src="<%= theme_script_src %>"></script>
  </body>
</html>
